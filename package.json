    "@sentry/react": "^10.58.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "filecoin-pin": "^0.23.2",
    "lucide-react": "^1.21.0",
    "multiformats": "^14.0.0",
    "pino": "^10.0.0",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
